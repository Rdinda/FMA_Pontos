56525410-8528-415b-b2f5-c0546fa0d69f	lyrics	04bfe00b-fd2a-6b0d-01eb-ebfffe89d234	UPDATE	{"id": "04bfe00b-fd2a-6b0d-01eb-ebfffe89d234", "title": "Vovó Maria do Rosário - O Galo cantou", "content": "O galo cantou\\nquando Jesus nasceu\\nMas também, ele cantou\\nQuando Maria do Rosário aqui chegou\\nViva aleluia,vivaaleluia\\nViva aleluiae Maria do Rosário", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "04bfe00b-fd2a-6b0d-01eb-ebfffe89d234", "title": "Vovó Maria do Rosário - O Galo cantou", "content": "O galo cantou\\nquando Jesus nasceu\\nMas também, ele cantou\\nQuando Maria do Rosário aqui chegou\\nViva aleluia,vivaaleluia\\nViva aleluiae Maria do Rosário", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": 157}	\N	\N	2026-01-14 16:59:50.544055+00
8e584fff-7e50-428c-9963-b914cc71a5ce	lyrics	2a5f8aaf-2b3a-1f00-3eb1-1dcf93b30984	UPDATE	{"id": "2a5f8aaf-2b3a-1f00-3eb1-1dcf93b30984", "title": "Vovó Maria Redonda - Filho se suncê precisar", "content": "\\"fio\\"se \\"suncê\\" \\"precisá\\"\\né só pensar na vovó que ela vem lhe ajudar\\nPensa numa estrada longa \\"ziofio\\"\\nláno seu jacutá\\nNuma casinha branca \\"zinfio\\"\\na vovó tá lá\\nSentada num banquinho tosco \\"zinfio\\"\\ncom sua rosário na mão\\npensa na vovó Maria Redonda\\nfazendo oração.", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "2a5f8aaf-2b3a-1f00-3eb1-1dcf93b30984", "title": "Vovó Maria Redonda - Filho se suncê precisar", "content": "\\"fio\\"se \\"suncê\\" \\"precisá\\"\\né só pensar na vovó que ela vem lhe ajudar\\nPensa numa estrada longa \\"ziofio\\"\\nláno seu jacutá\\nNuma casinha branca \\"zinfio\\"\\na vovó tá lá\\nSentada num banquinho tosco \\"zinfio\\"\\ncom sua rosário na mão\\npensa na vovó Maria Redonda\\nfazendo oração.", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": 158}	\N	\N	2026-01-14 16:59:50.544055+00
