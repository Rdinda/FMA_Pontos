ce1b1667-84df-4fa9-855b-571f54cf4437	lyrics	35b0f2bab11e95ad5799649cd87d3310	DELETE	{"id": "35b0f2bab11e95ad5799649cd87d3310", "title": "Caboclo Arranca Toco", "content": "Caboclo Arranca Toco,\\nA tua luz é minha guia,\\nTu és Oxóssi,\\nÉs filho da Virgem Maria,\\nA tua luz ilumina no escuro,\\nTodos os filhos do Terreiro,\\nEstão seguros.", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "8e182b4b-1b3d-45a1-a2e7-64d3f805ff72", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=MiHtWqp0cUg"}	\N	\N	\N	2026-01-14 15:44:11.207438+00
