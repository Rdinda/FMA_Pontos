5fea69cc-d64a-4b42-bc40-0071edd5b2bd	lyrics	f0568a52bf2d2d909ad888b4ed2c1df9	DELETE	{"id": "f0568a52bf2d2d909ad888b4ed2c1df9", "title": "Cabocla Jurema", "content": "A Estrela d'Alva lá no Céu apareceu,\\nAs matas de Oxóssi ilumi-nou... (bis)\\nJurema Tronqueira!...\\nSaia das matas com seus filhos,\\nO Juremedo. (bis)\\nCabelos longos, olhar dis-tante,\\nSua galera enternecida, o Juremedo,\\nJurema Tronqueira!...\\nSaia das matas com seus filhos,\\nO Juremedo. (bis)", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "8e182b4b-1b3d-45a1-a2e7-64d3f805ff72", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=wCBcqrasnWA"}	\N	\N	\N	2026-01-14 15:44:11.207438+00
