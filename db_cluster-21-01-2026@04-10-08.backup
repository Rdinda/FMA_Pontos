d3d6cc20-ba51-4dca-b80f-2a0c36de9a5f	lyrics	6b9cf738f2020afff264f2fb9a907076	INSERT	\N	{"id": "6b9cf738f2020afff264f2fb9a907076", "title": "Passarinho Azulão", "content": "Olha o meu passarinho azulão\\nQuando ele voa não pousa no chão\\nMas que lindo caboclo de pena\\nCom sua flecha\\nE o bodoque na mão", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "8e182b4b-1b3d-45a1-a2e7-64d3f805ff72", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=4J4UQaFfikc"}	\N	\N	2026-01-12 22:59:46.371749+00
b9a91182-1510-49de-8f90-dea93e842d03	lyrics	5a8e0845b5ce3a55b971cbdbceaa1f5c	INSERT	\N	{"id": "5a8e0845b5ce3a55b971cbdbceaa1f5c", "title": "Pedrinho", "content": "Ele é uma criança\\nEle é um êre\\nQuando as ondas balançam saravá\\nÉ Pedrinho que vai descer\\nVem criança da praia\\nVem criança na areia\\nEle é filho de Iemanjá\\nEle é filho da Sereia.\\n\\nEle é uma criança\\nEle é um êre\\nQuando as ondas balançam saravá\\nÉ Pedrinho que vai descer\\nVem criança da praia\\nVem criança na areia\\nEle é filho de Iemanjá\\nEle é filho da Sereia.", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "ac24acca-ce30-44e2-975f-3a07120ac5e2", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=PbWdxlLTyd0"}	\N	\N	2026-01-12 22:59:46.371749+00
