30bafc5f-0fde-4db0-bdcb-633dfd4f1d17	lyrics	a231d8c8-550b-f240-ab79-73d6423796cb	UPDATE	{"id": "a231d8c8-550b-f240-ab79-73d6423796cb", "title": "Pretos Velhos - Vovó Maria da Guia", "content": "Vovó Maria da Guia\\nTraz as forças láda Bahia.\\nVovó Maria da Guia\\nTraz as forças láda Bahia.\\nPreta velha rezadeira,\\nTodo mal ela desfaz,\\nPreta velha mirongueira,\\nA razão da minha paz.\\nNa sua sacola ela traz\\nUm galhinho de vence-demanda,\\nAroeira, rosas brancas\\nE um rosário de guiné.\\nNo cruzeiro abençoado,\\nTrabalha pra quem tem fé.\\nVovó Maria da Guia\\nTraz as forças láda Bahia.\\nVovó Maria da Guia\\nTraz as forças láda Bahia.\\nPreta velha rezadeira,\\nTodo mal ela desfaz,\\nPreta velha mirongueira,\\nA razão da minha paz.\\nNa sua sacola ela traz\\nUm galhinho de vence-demanda,\\nAroeira, rosas brancas\\nE um rosário de guiné.\\nNo cruzeiro abençoado,\\nTrabalha pra quem tem fé.", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "a231d8c8-550b-f240-ab79-73d6423796cb", "title": "Pretos Velhos - Vovó Maria da Guia", "content": "Vovó Maria da Guia\\nTraz as forças láda Bahia.\\nVovó Maria da Guia\\nTraz as forças láda Bahia.\\nPreta velha rezadeira,\\nTodo mal ela desfaz,\\nPreta velha mirongueira,\\nA razão da minha paz.\\nNa sua sacola ela traz\\nUm galhinho de vence-demanda,\\nAroeira, rosas brancas\\nE um rosário de guiné.\\nNo cruzeiro abençoado,\\nTrabalha pra quem tem fé.\\nVovó Maria da Guia\\nTraz as forças láda Bahia.\\nVovó Maria da Guia\\nTraz as forças láda Bahia.\\nPreta velha rezadeira,\\nTodo mal ela desfaz,\\nPreta velha mirongueira,\\nA razão da minha paz.\\nNa sua sacola ela traz\\nUm galhinho de vence-demanda,\\nAroeira, rosas brancas\\nE um rosário de guiné.\\nNo cruzeiro abençoado,\\nTrabalha pra quem tem fé.", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "ca