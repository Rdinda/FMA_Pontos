--
-- Name: objects Upload Audio; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Upload Audio" ON storage.objects FOR INSERT TO authenticated WITH CHECK (((bucket_id = 'audio'::text) AND (name ~~* '%.mp3'::text) AND public.has_role('user'::text)));


