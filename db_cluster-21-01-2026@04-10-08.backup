49d48352-c0af-4f71-a5c8-e2fb7c779b54	lyrics	cb5ac112-b7b2-35b4-0d60-2d98feff8aec	UPDATE	{"id": "cb5ac112-b7b2-35b4-0d60-2d98feff8aec", "title": "Ogum - Ogum meu pai", "content": "Ogum, Ogum meu pai\\nolhaipor nós aqui na terra\\nOgum meu pai\\ndia23 de abril,os\\nclarinsjávão tocar\\nabram alasno terreiro\\nafalange vai chegar\\nvou chamar seu beira mar\\nOgum iara,Ogum megê\\nSete ondas, Rompe mato\\nfirmaa gira,eu quero ver\\nOgum, Ogum meu pai\\nolhaipor nós aqui na terra\\nOgum meu pai\\nláno céu brilhando a lua\\navisteimeu padroeiro\\nvendo a imagem de São Jorge\\nrezeipra Ogum guerreiro\\nas batalhas dessa vida\\ncom meu paihei de vencer\\nfortemente chega armado\\npronto pra me defender", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "cb5ac112-b7b2-35b4-0d60-2d98feff8aec", "title": "Ogum - Ogum meu pai", "content": "Ogum, Ogum meu pai\\nolhaipor nós aqui na terra\\nOgum meu pai\\ndia23 de abril,os\\nclarinsjávão tocar\\nabram alasno terreiro\\nafalange vai chegar\\nvou chamar seu beira mar\\nOgum iara,Ogum megê\\nSete ondas, Rompe mato\\nfirmaa gira,eu quero ver\\nOgum, Ogum meu pai\\nolhaipor nós aqui na terra\\nOgum meu pai\\nláno céu brilhando a lua\\navisteimeu padroeiro\\nvendo a imagem de São Jorge\\nrezeipra Ogum guerreiro\\nas batalhas dessa vida\\ncom meu paihei de vencer\\nfortemente chega armado\\npronto pra me defender", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": 51}	\N	\N	2026-01-14 16:59:50.544055+00
