f7b195b3-0d02-4d96-b10f-89df56dc2442	lyrics	8125d7e3-3b08-d532-7c7c-a41afa76a589	UPDATE	{"id": "8125d7e3-3b08-d532-7c7c-a41afa76a589", "title": "Preto velho - Cativeiro já acabou", "content": "Preto na senzala bateu sua caixa deu viva iaiá\\nPreto na senzala bateu sua caixa de viva ioiô\\nViva iaiá\\nViva ioiô\\nViva nossa Senhora\\nocativeiro jáacabou", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "8125d7e3-3b08-d532-7c7c-a41afa76a589", "title": "Preto velho - Cativeiro já acabou", "content": "Preto na senzala bateu sua caixa deu viva iaiá\\nPreto na senzala bateu sua caixa de viva ioiô\\nViva iaiá\\nViva ioiô\\nViva nossa Senhora\\nocativeiro jáacabou", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": 51}	\N	\N	2026-01-14 16:59:50.544055+00
