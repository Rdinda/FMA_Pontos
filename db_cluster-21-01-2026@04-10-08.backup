216e517e-9ece-4bb6-b0e7-445070e86e93	lyrics	36e40b12-e690-1bee-22b0-d85e4d14b64c	UPDATE	{"id": "36e40b12-e690-1bee-22b0-d85e4d14b64c", "title": "Pai Chico", "content": "Conhecedor da reza que acalenta\\nÉ benzedor, o coração esquenta\\nPai Chico vem, Preto Velho vem\\nMironga com fé:Preto Velho tem\\nPai Chico vem, Preto Velho vem\\nCajado na mão: Preto Velho tem\\nAndando na beira do cafezal\\nCuidando dos novos a trabalhar\\nAssim Preto Velho dizia:\\n“Livrai-nosda fome e de todo o má”", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "36e40b12-e690-1bee-22b0-d85e4d14b64c", "title": "Pai Chico", "content": "Conhecedor da reza que acalenta\\nÉ benzedor, o coração esquenta\\nPai Chico vem, Preto Velho vem\\nMironga com fé:Preto Velho tem\\nPai Chico vem, Preto Velho vem\\nCajado na mão: Preto Velho tem\\nAndando na beira do cafezal\\nCuidando dos novos a trabalhar\\nAssim Preto Velho dizia:\\n“Livrai-nosda fome e de todo o má”", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": 17}	\N	\N	2026-01-14 16:59:50.544055+00
