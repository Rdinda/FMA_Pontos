39015724-67de-4d75-b3af-a0234030416e	lyrics	3e4fcb84-4120-c1e7-6f03-40394c07c248	UPDATE	{"id": "3e4fcb84-4120-c1e7-6f03-40394c07c248", "title": "Ogum - Bandeira içada", "content": "Bandeira içada é sinalde uma vitória\\nnos campos do Humaitá\\nena Umbanda vamos todos saravá\\nlindafalange que sabe guerrear\\nSeu Beira mar, Ogum Nagô\\nSeu Rompa mato, seu Ogum de lê\\nOgum iara,Seu Naruê\\neaí vem Seu Ogum Megê", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "3e4fcb84-4120-c1e7-6f03-40394c07c248", "title": "Ogum - Bandeira içada", "content": "Bandeira içada é sinalde uma vitória\\nnos campos do Humaitá\\nena Umbanda vamos todos saravá\\nlindafalange que sabe guerrear\\nSeu Beira mar, Ogum Nagô\\nSeu Rompa mato, seu Ogum de lê\\nOgum iara,Seu Naruê\\neaí vem Seu Ogum Megê", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": 5}	\N	\N	2026-01-14 16:59:50.544055+00
