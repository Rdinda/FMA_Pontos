83274bad-f7de-47cc-91d4-e2800110d44e	lyrics	1603bdf1-eb24-4293-9208-55d8022b5dbc	UPDATE	{"id": "1603bdf1-eb24-4293-9208-55d8022b5dbc", "title": "70 Anos Passei No Pé da Jurema", "content": "70 anos eu passei no pé da jurema\\nEu não tenho pena de quem me deseja o mal 2x\\n\\nSe eu me zangar, boto fogo no rochedo\\nMeu cachimbo é meu segredo, agora eu vou me vingar\\n\\nSe eu me zangar, boto fogo no rochedo\\nMeu cachimbo é meu segredo, agora eu vou me vingar\\n\\nEu quero um mestre que trabalhe na jurema\\nQue resolva os meus problemas na hora que eu precisar\\n\\nEu quero um mestre que trabalhe na jurema\\nQue resolva os meus problemas na hora que eu precisar\\n\\nEu chamei 1, chamei 2, eu chamei 3\\nChamei 7 de uma vez pra comigo trabalhar\\nEu chamei 1, chamei 2, eu chamei 3\\nChamei 7 de uma vez pra comigo trabalhar", "audio_url": "https://hlvvazkgzzoichdgkszf.supabase.co/storage/v1/object/public/audio/lyrics/e799fcca-fda9-455c-a3c6-ba0e1889aeb2_70_Anos_Eu_Passei_No_P_Da_Jurema.mp3", "updated_at": "2025-12-23T15:06:31.926833+00:00", "category_id": "8e182b4b-1b3d-45a1-a2e7-64d3f805ff72", "youtube_url": null, "youtube_link": null}	{"id": "1603bdf1-eb24-4293-9208-55d8022b5dbc", "title": "70 Anos Passei No Pé da Jurema", "content": "70 anos eu passei no pé da jurema\\nEu não tenho pena de quem me deseja o mal 2x\\n\\nSe eu me zangar, boto fogo no rochedo\\nMeu cachimbo é meu segredo, agora eu vou me vingar\\n\\nSe eu me zangar, boto fogo no rochedo\\nMeu cachimbo é meu segredo, agora eu vou me vingar\\n\\nEu quero um mestre que trabalhe na jurema\\nQue resolva os meus problemas na hora que eu precisar\\n\\nEu quero um mestre que trabalhe na jurema\\nQue resolva os meus problemas na hora que eu precisar\\n\\nEu chamei 1, chamei 2, eu chamei 3\\nChamei 7 de uma vez pra comigo trabalhar\\nEu chamei 1, chamei 2, eu chamei 3\\nChamei 7 de uma vez pra comigo trabalhar", "audio_url": "https://hlvvazkgzzoichdgkszf.supabase.co/storage/v1/object/public/audio/lyrics/e799fcca-f