f23cfc1a-416a-4983-82a8-7051300f15c0	lyrics	b761763fdd251b300401a86611c2ab43	DELETE	{"id": "b761763fdd251b300401a86611c2ab43", "title": "Preto Velho Campina", "content": "Cambinda mamanhê\\nCambinda Mamãe-nhã\\nOi segura a Cambina que eu quero ver\\nFilhos de Umbanda não tem querer\\nSegura a Cambinda que eu quero ver\\nFilhos de Umbanda não tem querer\\nO Povo de Cambinda\\nOi quando vem pra trabalhar\\nO Povo de Cambinda\\nOi quando vem pra trabalhar\\nTodo o povo vem por terra\\nCampinar vem pelo mar\\nTodo o povo vem por terra\\nCambinar vem pelo mar", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "7ea8ec81-de50-4c38-8d09-15e837fb3397", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=zgpJTpaS4PI"}	\N	\N	\N	2026-01-14 15:44:11.207438+00
