c2ccf632-f380-4383-8d19-cea78b1f451f	lyrics	9e2d7b77-9294-f55a-84bf-ff83d9a5ebf8	UPDATE	{"id": "9e2d7b77-9294-f55a-84bf-ff83d9a5ebf8", "title": "Nanã - Eu vi uma senhora", "content": "eu viuma senhora\\nlána beira da lagoa\\nde longe jáse via\\nobrilho da sua coroa[2x]\\neraNanã Buruquê\\nlavava o manto do seu filhoOxumarê [2x]", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "4f76dcef-433a-b1d1-b74b-cc24a54be4c6", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "9e2d7b77-9294-f55a-84bf-ff83d9a5ebf8", "title": "Nanã - Eu vi uma senhora", "content": "eu viuma senhora\\nlána beira da lagoa\\nde longe jáse via\\nobrilho da sua coroa[2x]\\neraNanã Buruquê\\nlavava o manto do seu filhoOxumarê [2x]", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "4f76dcef-433a-b1d1-b74b-cc24a54be4c6", "youtube_url": null, "youtube_link": null, "sequence_number": 13}	\N	\N	2026-01-14 16:59:50.544055+00
