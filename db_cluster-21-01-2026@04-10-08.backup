649ba286-4a30-4415-b342-23a8040c9b84	lyrics	32551326-c6ca-bfb5-18da-80ebc6ea55a1	UPDATE	{"id": "32551326-c6ca-bfb5-18da-80ebc6ea55a1", "title": "Vou acender velas para São Jorge", "content": "Vou acender velas para São Jorge\\nA eleeu quero agradecer\\nevou plantarcomigo niguém pode\\npara que o mau não possa então vencer\\nOlho grande em mim não pega\\nnão pega não\\nnão pega em quem tem fé\\nno coração\\nOgum com sua espada\\nsua capa encarnada\\nme dá sempre proteção\\nquem vaipela boa estrada\\nno fimdessa caminhada\\nencontra em Deus perdão\\nlálaiálaiálaiá laiá\\nvamos saudar São Jorge Cavaleiro", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "32551326-c6ca-bfb5-18da-80ebc6ea55a1", "title": "Vou acender velas para São Jorge", "content": "Vou acender velas para São Jorge\\nA eleeu quero agradecer\\nevou plantarcomigo niguém pode\\npara que o mau não possa então vencer\\nOlho grande em mim não pega\\nnão pega não\\nnão pega em quem tem fé\\nno coração\\nOgum com sua espada\\nsua capa encarnada\\nme dá sempre proteção\\nquem vaipela boa estrada\\nno fimdessa caminhada\\nencontra em Deus perdão\\nlálaiálaiálaiá laiá\\nvamos saudar São Jorge Cavaleiro", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": 108}	\N	\N	2026-01-14 16:59:50.544055+00
