--
-- Name: user_roles Users can read own role; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can read own role" ON public.user_roles FOR SELECT USING ((id = auth.uid()));


--
-- Name: lyric_play_stats Users can read play stats; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can read play stats" ON public.lyric_play_stats FOR SELECT USING (true);


--
-- Name: lyric_play_stats Users can update play stats; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can update play stats" ON public.lyric_play_stats FOR UPDATE TO authenticated USING (true);


