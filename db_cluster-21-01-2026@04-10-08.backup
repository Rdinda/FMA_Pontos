48733e09-fd8d-4b68-9fa4-8ab84d1fc14e	lyrics	433b87d5-f65e-0322-ab89-13732e05a192	UPDATE	{"id": "433b87d5-f65e-0322-ab89-13732e05a192", "title": "Obaluaê - Ele é Xapanã", "content": "Na pedra fria\\nNo pé do morro\\nDizem que mora\\nUm velho lá- 2x\\nEleé curador\\nEleé rezador\\nEleé Xapanã\\nElevai me curar -2x", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "fc694bba-8c71-f762-b0f3-705b93a5c8ad", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "433b87d5-f65e-0322-ab89-13732e05a192", "title": "Obaluaê - Ele é Xapanã", "content": "Na pedra fria\\nNo pé do morro\\nDizem que mora\\nUm velho lá- 2x\\nEleé curador\\nEleé rezador\\nEleé Xapanã\\nElevai me curar -2x", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "fc694bba-8c71-f762-b0f3-705b93a5c8ad", "youtube_url": null, "youtube_link": null, "sequence_number": 4}	\N	\N	2026-01-14 16:59:50.544055+00
