6a4b9a4f-72c4-47be-bf96-5f481443a209	lyrics	757cb76546640a546176d85cc821003d	DELETE	{"id": "757cb76546640a546176d85cc821003d", "title": "Cabloco Boiadeiro", "content": "Boa noite, meus senhores\\nBoa noite, meus senhores\\nDa licença para um cavalheiro\\nDai me licença para um cavalheiro\\n\\nÉ que eu morei em mata serrada\\nEu passei por mata serrada\\nO meu nome é caboclo vaqueiro\\nMas o meu nome é caboclo vaqueiro\\n\\nOh que Deus salve a casa santa\\nQue Deus salve a casa santa\\nOnde Deus fez a sua morada\\nAonde Deus fez sua morada\\n\\nAonde mora o cálice Bento\\nE a hóstia consagrada\\nE a hóstia consagrada", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "c5dfb335-d0fe-441b-90fb-0e44e738e6ad", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=arJX1tqS750"}	\N	\N	\N	2026-01-14 15:44:11.207438+00
