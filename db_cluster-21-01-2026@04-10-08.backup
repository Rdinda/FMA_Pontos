24164f28-747a-46e0-b4ed-bbb865e1e84d	lyrics	2f5d32af-3926-0e7e-0c5f-7fd99282a388	UPDATE	{"id": "2f5d32af-3926-0e7e-0c5f-7fd99282a388", "title": "Preto Velho - Negra Cambinda", "content": "Nega Cambinda, nega da costa do mar\\nnega da costa mina, filhade yalorixá\\nna macumba ê,na macumba á\\nnegro canta, negro dança, na batida do tambor\\nnegro bebe seu marafo, saravá seu protetor", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "2f5d32af-3926-0e7e-0c5f-7fd99282a388", "title": "Preto Velho - Negra Cambinda", "content": "Nega Cambinda, nega da costa do mar\\nnega da costa mina, filhade yalorixá\\nna macumba ê,na macumba á\\nnegro canta, negro dança, na batida do tambor\\nnegro bebe seu marafo, saravá seu protetor", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "1133e4d7-5f35-9e21-9c76-9518b0c3488e", "youtube_url": null, "youtube_link": null, "sequence_number": 80}	\N	\N	2026-01-14 16:59:50.544055+00
