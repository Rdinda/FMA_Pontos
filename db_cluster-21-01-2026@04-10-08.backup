167e0e19-c55c-4fea-8020-61faaa5961a5	lyrics	f6a87f7d43e39a6c71186a63ec9aad60	DELETE	{"id": "f6a87f7d43e39a6c71186a63ec9aad60", "title": "Exú da Boca da Mata", "content": "Exu da Boca da Mata, oi dá licença, que eu preciso passar – (bis)\\nEu venho saravá a Umbanda, na aldeia da Juremá\\nEspere uma folha cair: diz Exu\\nEspere uma ave cantar\\nDepois você pode seguir que a Jurema\\nE Oxóssi vão lhe acompanhar", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "ac24acca-ce30-44e2-975f-3a07120ac5e2", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=tlJNvC9u6r4"}	\N	\N	\N	2026-01-14 15:44:11.207438+00
