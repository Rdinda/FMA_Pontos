--
-- Name: user_roles Admins can update user roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admins can update user roles" ON public.user_roles FOR UPDATE USING (public.is_admin(auth.uid()));


--
-- Name: user_roles Authenticated can read all user roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Authenticated can read all user roles" ON public.user_roles FOR SELECT TO authenticated USING (true);


--
-- Name: categories Delete Categories; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Delete Categories" ON public.categories FOR DELETE USING (((auth.role() = 'authenticated'::text) AND (((auth.jwt() ->> 'is_anonymous'::text))::boolean IS NOT TRUE) AND public.has_role('admin'::text)));


--
-- Name: lyrics Delete Lyrics; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Delete Lyrics" ON public.lyrics FOR DELETE USING (((auth.role() = 'authenticated'::text) AND (((auth.jwt() ->> 'is_anonymous'::text))::boolean IS NOT TRUE) AND public.has_role('admin'::text)));


--
-- Name: categories Insert Categories; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Insert Categories" ON public.categories FOR INSERT WITH CHECK (((auth.role() = 'authenticated'::text) AND (((auth.jwt() ->> 'is_anonymous'::text))::boolean IS NOT TRUE) AND public.has_role('moderator'::text)));


--
-- Name: lyrics Insert Lyrics; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Insert Lyrics" ON public.lyrics FOR INSERT WITH CHECK (((auth.role() = 'authenticated'::text) AND (((auth.jwt() ->> 'is_anonymous'::text))::boolean IS NOT TRUE) AND public.has_role('user'::text)));


--
-- Name: categories Read Categories; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Read Categories" ON public.categories FOR SELECT USING (true);


--
-- Name: lyrics Read Lyrics; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Read Lyrics" ON public.lyrics FOR SELECT USING (true);


--
-- Name: categories Update Categories; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Update Categories" ON public.categories FOR UPDATE USING (((auth.role() = 'authenticated'::text) AND (((auth.jwt() ->> 'is_anonymous'::text))::boolean IS NOT TRUE) AND public.has_role('moderator'::text)));


--
-- Name: lyrics Update Lyrics; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Update Lyrics" ON public.lyrics FOR UPDATE USING (((auth.role() = 'authenticated'::text) AND (((auth.jwt() ->> 'is_anonymous'::text))::boolean IS NOT TRUE) AND public.has_role('moderator'::text)));


--
-- Name: user_roles Users can insert own role; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can insert own role" ON public.user_roles FOR INSERT WITH CHECK ((id = auth.uid()));


