b0e8ee46-6728-4991-b74a-ec9bf4592ae6	lyrics	70b00a3d-68b0-9d65-7dd6-033901df445a	UPDATE	{"id": "70b00a3d-68b0-9d65-7dd6-033901df445a", "title": "Cabocla Jurema -Serenou tanto, Jurema", "content": "Jurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nJurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nEstava na mata caçando\\nPara os filhosde Vovó Maria\\nQuando me disseram\\nQue minha conga caia\\nSai pelas matas correndo\\nPara ver o que acontecia\\nQuando eu cheguei na tenda\\nOs meus inimigos caindo\\nÉ que eu vi,oh,Jurema\\nJurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nJurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nEstava na mata caçando\\nPara os filhosde Vovó Maria\\nQuando me disseram\\nQue minha conga caia\\nSai pelas matas correndo\\nPara ver o que acontecia\\nQuando eu cheguei na tenda\\nOs meus inimigos caindo\\nÉ que eu vi,oh, Jurema\\nJurema\\nSerenou tanto,oh, Jurema\\nJurema\\nSerenou tanto,oh, Jurema", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "68be09dc-e73d-ff41-1589-220baaea442d", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "70b00a3d-68b0-9d65-7dd6-033901df445a", "title": "Cabocla Jurema -Serenou tanto, Jurema", "content": "Jurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nJurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nEstava na mata caçando\\nPara os filhosde Vovó Maria\\nQuando me disseram\\nQue minha conga caia\\nSai pelas matas correndo\\nPara ver o que acontecia\\nQuando eu cheguei na tenda\\nOs meus inimigos caindo\\nÉ que eu vi,oh,Jurema\\nJurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nJurema\\nSerenou tanto, oh,Jurema\\nNão molhou nem a minha guia\\nOh, Jurema\\nEstava na mata caçando\\nPara os filhosde Vovó Maria\\nQuando me disseram\\nQue minha conga caia\\nSai pelas matas correndo\\nPara ver o que acontecia\\nQuando eu cheguei na tenda\\nOs meus inimigos caindo\\nÉ que eu vi,oh, Jurema\\nJurema\\nSerenou tanto,oh, Jurema\\nJurema\\nSerenou tanto,oh, Jurema", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "68be09dc-e73d-ff41-1589-220baaea442d", "youtube_url": null, "youtube_link": null, "sequence_number": 32}	\N	\N	2026-01-14 16:59:50.544055+00
