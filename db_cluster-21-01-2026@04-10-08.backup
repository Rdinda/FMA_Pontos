df3ed274-17cb-47e0-9da5-d470c4349c4c	lyrics	02a2455d7d0fd29ab9dd5bd174d307cc	DELETE	{"id": "02a2455d7d0fd29ab9dd5bd174d307cc", "title": "Bate palma pra Damião", "content": "Vou pedir licença à Zamby e ao Sagrado Coração\\nVamos todos bater palmas pra São Cosme e Damião\\nVou pedir licença à Zamby e ao Sagrado Coração\\nVamos todos bater palmas pra São Cosme e Damião", "audio_url": null, "updated_at": "2026-01-12T22:59:46.371749+00:00", "category_id": "ac24acca-ce30-44e2-975f-3a07120ac5e2", "youtube_url": null, "youtube_link": "https://www.youtube.com/watch?v=u1fx0Yhmz2A"}	\N	\N	\N	2026-01-14 15:44:11.207438+00
