d0cf2353-1206-4970-8a19-d7c3c707d3cc	lyrics	2f0e04b7-1728-bbfc-4134-02cb11f8ddd1	UPDATE	{"id": "2f0e04b7-1728-bbfc-4134-02cb11f8ddd1", "title": "Caboclos das matas", "content": "Caboclos, das matas\\ndas cachoeiras\\ndas pedras das pedreiras\\ndas ondas do mar\\nCaboclas, guerreiras\\nmensageiras\\nda paz e da harmonia\\nsoldados de Oxalá\\nVem de Aruanda, vem, vem ,vem\\ntrazendo forças, vem, vem, vem\\nquebrando mirongas, vem, vem, vem\\nna Umbanda saravá", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "68be09dc-e73d-ff41-1589-220baaea442d", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "2f0e04b7-1728-bbfc-4134-02cb11f8ddd1", "title": "Caboclos das matas", "content": "Caboclos, das matas\\ndas cachoeiras\\ndas pedras das pedreiras\\ndas ondas do mar\\nCaboclas, guerreiras\\nmensageiras\\nda paz e da harmonia\\nsoldados de Oxalá\\nVem de Aruanda, vem, vem ,vem\\ntrazendo forças, vem, vem, vem\\nquebrando mirongas, vem, vem, vem\\nna Umbanda saravá", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "68be09dc-e73d-ff41-1589-220baaea442d", "youtube_url": null, "youtube_link": null, "sequence_number": 185}	\N	\N	2026-01-14 16:59:50.544055+00
