27601ef6-58f5-4174-8c38-fa70f6ed9966	lyrics	5c248ae7-c746-e2e2-cefd-78dba4aefdde	UPDATE	{"id": "5c248ae7-c746-e2e2-cefd-78dba4aefdde", "title": "Ogum - Eu não seria nada", "content": "Eu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nValente guerreiro\\nAqui chegou\\nVencedor de demandas\\nMeu protetor\\nEm sua trajetória\\nMeu pailuta contra o mal\\nFoinos campos de batalha\\nQue se tornou um general\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nSalve Ogum de Ronda\\nSalve Ogum Megê\\nSaravá Beira-Mar\\nOgum Iara e Ogum Dilê\\nSalve toda falange\\nDesse glorioso guerreiro\\nMeu paivence demandas\\nAqui dentro do terreiro\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada", "audio_url": null, "updated_at": "2026-01-14T15:51:43.242005+00:00", "category_id": "3aa816f2-5a7f-aaa2-ea9a-200a4f71cc6e", "youtube_url": null, "youtube_link": null, "sequence_number": null}	{"id": "5c248ae7-c746-e2e2-cefd-78dba4aefdde", "title": "Ogum - Eu não seria nada", "content": "Eu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nValente guerreiro\\nAqui chegou\\nVencedor de demandas\\nMeu protetor\\nEm sua trajetória\\nMeu pailuta contra o mal\\nFoinos campos de batalha\\nQue se tornou um general\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada\\nSalve Ogum de Ronda\\nSalve Ogum Megê\\nSaravá Beira-Mar\\nOgum Iara e Ogum Dilê\\nSalve toda falange\\nDesse glorioso guerreiro\\nMeu paivence demandas\\nAqui dentro do terreiro\\nEu não seria\\nEu não serianada\\nSe não fosse Ogum\\nPara abrira minha estrada", "audio_url": null, "updated_at